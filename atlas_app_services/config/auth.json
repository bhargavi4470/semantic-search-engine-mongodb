{
  "custom_user_data": {
    "enabled": true,
    "mongo_service_name": "mongodb-atlas",
    "database_name": "semantic_search",
    "collection_name": "users_metadata",
    "user_id_field": "user_id"
  },
  "providers": {
    "api-key": {
      "name": "api-key",
      "type": "api-key",
      "disabled": false
    },
    "local-userpass": {
      "name": "local-userpass",
      "type": "local-userpass",
      "disabled": false,
      "config": {
        "autoConfirm": true,
        "resetPasswordUrl": "",
        "runConfirmationFunction": false,
        "runResetFunction": false
      }
    }
  }
}
